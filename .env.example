# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=trackpro
POSTGRES_USER=trackpro
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -hex 64
TRACKPRO_JWT_SECRET=CHANGE_ME_VERY_LONG_RANDOM_SECRET_AT_LEAST_64_CHARS
TRACKPRO_JWT_ISSUER=trackpro

# ── Bootstrap admin (created on first startup) ────────────────────────────────
TRACKPRO_BOOTSTRAP_ADMIN_ENABLED=true
TRACKPRO_BOOTSTRAP_ADMIN_EMAIL=admin@yourdomain.com
TRACKPRO_BOOTSTRAP_ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
TRACKPRO_BOOTSTRAP_ADMIN_DISPLAY_NAME=Admin

# ── TCP (GPS tracker port) ────────────────────────────────────────────────────
TRACKPRO_TCP_PORT=5023
TRACKPRO_TCP_ENABLED=true

# ── MQTT ─────────────────────────────────────────────────────────────────────
TRACKPRO_MQTT_ENABLED=true
TRACKPRO_MQTT_CLIENT_ID=trackpro-backend

# ── SSL / Domain ──────────────────────────────────────────────────────────────
DOMAIN=api.yourdomain.com
CERTBOT_EMAIL=you@yourdomain.com

# ── SMS Provider — set to "termii" or "africastalking" ────────────────────────
SMS_PROVIDER=termii

# ── Termii credentials (used when SMS_PROVIDER=termii) ────────────────────────
# Get your API key at: https://termii.com → Dashboard → API Tokens
TERMII_API_KEY=CHANGE_ME_TERMII_API_KEY
# Sender ID must be registered & approved in your Termii account
TERMII_SENDER_ID=N-Alert
TERMII_BASE_URL=https://api.ng.termii.com

# ── Africa's Talking credentials (used when SMS_PROVIDER=africastalking) ───────
# Get your API key at: https://africastalking.com → Dashboard → Settings → API Key
AT_API_KEY=CHANGE_ME_AT_API_KEY
AT_USERNAME=CHANGE_ME_AT_USERNAME
AT_SENDER_ID=STTracker
# Set to true in development to use Africa's Talking sandbox (free)
AT_SANDBOX=false

# Optional shared secret sent as X-TrackPro-Sms-Secret header or secret query/form param
SMS_WEBHOOK_SECRET=CHANGE_ME_SMS_WEBHOOK_SECRET
SMS_DELIVERY_STATUS_ENABLED=true

# Public hostname of this server — sent to devices via SMS to configure the TCP server endpoint
# e.g. api.yourfleet.com (no protocol, no port)
TRACKPRO_SERVER_HOST=api.yourdomain.com

TRACKPRO_DEVICE_SECRET_KEY=CHANGE_ME_BASE64_32_BYTE_KEY

# Optional command overrides per manufacturer. Placeholders: {host}, {port}, {apn}, {imei}, {manufacturer}
SMS_GENERIC_SERVER_COMMAND=SERVER,1,{host},{port},0
SMS_GENERIC_APN_COMMAND=APN,{apn}
SMS_GENERIC_STATUS_COMMAND=STATUS
SMS_CONCOX_SERVER_COMMAND=SERVER,1,{host},{port},0
SMS_CONCOX_APN_COMMAND=APN,{apn}
SMS_CONCOX_STATUS_COMMAND=STATUS
SMS_TELTONIKA_SERVER_COMMAND=SERVER,1,{host},{port},0
SMS_TELTONIKA_APN_COMMAND=APN,{apn}
SMS_TELTONIKA_STATUS_COMMAND=STATUS
